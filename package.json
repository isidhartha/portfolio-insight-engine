{
  "name": "stock-portfolio-report-tool",
  "version": "1.0.0",
  "description": "Automated weekly stock portfolio summary emails via Trigger.dev, yfin.dev, OpenAI, and Resend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--no-deprecation npx trigger.dev@latest dev",
    "deploy": "NODE_OPTIONS=--no-deprecation npx trigger.dev@latest deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openai/agents": "^0.8.3",
    "@trigger.dev/build": "4.4.6",
    "@trigger.dev/sdk": "4.4.6",
    "canvas": "^2.11.2",
    "chart.js": "^4.4.0",
    "chartjs-node-canvas": "^5.0.0",
    "csv-parse": "^5.5.6",
    "openai": "^4.47.0",
    "resend": "^3.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
